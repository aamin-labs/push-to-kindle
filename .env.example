# Required
KINDLE_EMAIL=yourname@kindle.com

# Optional (macOS / Mail.app): pin a specific account to send from.
# If unset, Mail.app uses its default account.
# Set this so you know which email to add to Amazon's approved senders list.
# SENDER_EMAIL=you@example.com

# Required on Linux / Windows (or on macOS if you prefer SMTP over Mail.app).
# Use an app-specific password, not your main account password.
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
