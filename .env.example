# Required
KINDLE_EMAIL=yourname@kindle.com

# Required for sending to Kindle via SMTP.
# Use an app-specific password, not your main account password.
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password

# Optional: poll Gmail label -> Kindle.
# Defaults IMAP_USER/PASSWORD to SMTP_USER/PASSWORD when omitted.
# IMAP_SERVER=imap.gmail.com
# IMAP_USER=you@gmail.com
# IMAP_PASSWORD=your-app-password
# KINDLE_GMAIL_LABEL=Kindle
# KINDLE_PROCESSED_LABEL=Kindle/Sent
